{
  "name": "tab-organizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chrome MV3 擴充功能：分類分頁、HEAD 檢查 404、截圖保留 URL、關閉分頁釋放記憶體",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ltangyu/TabOrganizer.git"
  },
  "homepage": "https://github.com/ltangyu/TabOrganizer#readme",
  "bugs": {
    "url": "https://github.com/ltangyu/TabOrganizer/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "preview:dev": "vite --config vite.preview.config.ts",
    "icons": "node scripts/generate-icons.mjs",
    "package": "npm run build && powershell -Command \"Compress-Archive -Path dist/* -DestinationPath releases/TabOrganizer-v$(node -p require('./package.json').version)-portable.zip -Force\""
  },
  "dependencies": {
    "vue": "^3.5.0",
    "pinia": "^2.2.0",
    "dexie": "^4.0.8"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.270",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "~5.6.0",
    "vue-tsc": "^2.1.0",
    "vite": "^5.4.0"
  }
}
